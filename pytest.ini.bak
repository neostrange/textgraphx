[pytest]
# pytest configuration for textgraphx

testpaths = tests
python_files = test_*.py
python_classes = Test*
python_functions = test_*

# Add verbose output
addopts = -v --tb=short --strict-markers

# Coverage options
# addopts = --cov=textgraphx --cov-report=html --cov-report=term-missing

# Markers for organizing tests
markers =
    unit: Unit tests for individual components
    integration: Integration tests across components
    regression: Regression tests that capture existing behaviour
    scenario: Scenario tests covering end-to-end orchestration behavior
    slow: Tests that take a long time to run
    orchestration: Tests for the orchestration modules
