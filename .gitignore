# ── Virtual environments ────────────────────────────────────────────────────
venv/
env/
.venv/
.venv310/

# ── Python build / packaging artefacts ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/
*.egg
MANIFEST

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Logs (generated at runtime) ─────────────────────────────────────────────
*.log

# ── Generated evaluation / run outputs ──────────────────────────────────────
# Keep named reports that are intentionally committed under docs/ or
# datastore/evaluation/; ignore loose artefacts at the root.
/out/
/eval_*.json
/eval_*.log
/eval_*.csv
/eval_report_strict.json
/eval_report_strict.md
/eval_report_strict_docs.csv
/eval_report_strict_summary.csv
/eval_discourse_only.json
/eval_nominal_filtered.json
/eval_nominal_filtered_unlimited.json
/single_eval.json
/audit_output.json
/strict_events_summary.json
/cycle_log.txt
/cycle_log2.txt
/doc_tokens.txt
/bytecode.txt
/report.txt
/rel_examples.txt

# Generated by one-off tooling (not source assets)
/tools/nominals_*.json
/src/textgraphx/tools/nominals_*.json
/src/textgraphx/out/

# Evaluation artifact retention policy: keep only curated baseline/latest snapshots.
/src/textgraphx/datastore/evaluation/**
!/src/textgraphx/datastore/evaluation/
!/src/textgraphx/datastore/evaluation/README.md
!/src/textgraphx/datastore/evaluation/baseline/
!/src/textgraphx/datastore/evaluation/baseline/**
!/src/textgraphx/datastore/evaluation/latest/
!/src/textgraphx/datastore/evaluation/latest/**

# ── Patch files (applied; kept under version control in scripts/archive/) ───
# Loose .patch files at repo root are artefacts, not deliverables.
/*.patch

# ── Large generated datastore copies ────────────────────────────────────────
datastore/**/copy_of_current_latest/
datastore/evaluation/tmp_gold_xml/
datastore/evaluation/tmp_pred_xml/
/src/textgraphx/datastore/**/* copy.naf

# ── Runtime config (contains secrets) ───────────────────────────────────────
config.ini
textgraphx/config.ini

# ── Development artefacts ────────────────────────────────────────────────────
MagicMock/
backup_code/
converted_backups/
.pytest_cache/
