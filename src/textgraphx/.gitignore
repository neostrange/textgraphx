# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environments
venv/
env/
.venv/

# Logs
*.log

# Backup and converted files created during development
backup_code/
converted_backups/

# Compiled python artifacts
*.pyc

# OS files
.DS_Store
Thumbs.db

# Large generated datastore copies (subfolders)
datastore/**/copy_of_current_latest/

# Temporary evaluation XML mirror directories
datastore/evaluation/tmp_gold_xml/
datastore/evaluation/tmp_pred_xml/

# Ignore editor temporary files
*.swp
*.swo
config.ini
