# textgraphx — environment variable template
#
# DO NOT put real credentials here. This file is checked into git as a
# reference. For local use, copy values into a private location:
#
#   mkdir -p ~/.config/textgraphx
#   cp .env.example ~/.config/textgraphx/env
#   chmod 600 ~/.config/textgraphx/env
#   # then edit ~/.config/textgraphx/env with real values
#
# ~/.bashrc and ~/.profile auto-source ~/.config/textgraphx/env if present,
# so VS Code (including remote/tunnel sessions) and MCP servers inherit
# these vars without any per-session export.

# Neo4j connection (used by pipeline + .vscode/mcp.json neo4j-cypher server)
export NEO4J_URI="bolt://localhost:7687"
export NEO4J_USERNAME="neo4j"
export NEO4J_PASSWORD="changeme"
export NEO4J_DATABASE="neo4j"
